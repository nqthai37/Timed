<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/bg_recurrence_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Custom recurrence"
        android:textColor="@color/slate_900"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeat every"
            android:textColor="@color/slate_600"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etCustomInterval"
            android:layout_width="58dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_recurrence_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="3"
            android:text="1"
            android:textColor="@color/slate_900"
            android:textSize="20sp" />

        <Spinner
            android:id="@+id/spCustomFrequencyUnit"
            android:layout_width="118dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_recurrence_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:spinnerMode="dropdown" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sectionCustomByDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeat on"
            android:textColor="@color/slate_600"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipSun"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Su"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipMon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Mo"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipTue"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Tu"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipWed"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="We"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipThu"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Th"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFri"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Fr"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipSat"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_recurrence_day_chip_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Sa"
                android:textColor="@color/recurrence_day_chip_text"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Ends"
        android:textColor="@color/slate_600"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/rowEndNever"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbEndNever"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Never"
            android:textColor="@color/slate_900"
            android:textSize="17sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowEndOnDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbEndOnDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On date"
            android:textColor="@color/slate_900"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvEndDateValue"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_recurrence_input"
            android:gravity="center"
            android:text="29/06/2026"
            android:textColor="@color/slate_900"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowEndAfterCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbEndAfterCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="After"
            android:textColor="@color/slate_900"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etEndAfterValue"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_recurrence_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="5"
            android:text="13"
            android:textColor="@color/slate_900"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="occurrences"
            android:textColor="@color/slate_900"
            android:textSize="17sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Exception dates"
        android:textColor="@color/slate_600"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/etCustomExceptionDates"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_recurrence_input"
        android:hint="yyyy-MM-dd, separated by commas"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/slate_900"
        android:textColorHint="@color/slate_400"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCustomCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Cancel"
            android:textColor="@color/primary"
            android:textSize="21sp" />

        <Button
            android:id="@+id/btnCustomDone"
            android:layout_width="118dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_recurrence_done_button"
            android:text="Done"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
