<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_item_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_r_arrow"
            android:layout_marginEnd="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_title"
                android:text="Auto Sync"
                android:textSize="15sp"
                android:textColor="#FF0F172A"
                android:textStyle="bold"
                android:fontFamily="Inter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_item_desc"
                android:text="Sync changes automatically"
                android:textSize="12.5sp"
                android:textColor="#FF64748B"
                android:fontFamily="Inter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <Switch
            android:id="@+id/switch_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_storage_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:text="Cloud Storage"
                android:textSize="13sp"
                android:textColor="#FF000000"
                android:fontFamily="Inter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_storage_usage"
                android:text="1.2 GB / 5 GB"
                android:textSize="14sp"
                android:textColor="#FF64748B"
                android:fontFamily="Inter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_rounded">

            <View
                android:layout_width="54dp"
                android:layout_height="match_parent"
                android:background="#FF3B82F6" />

            <View
                android:layout_width="90dp"
                android:layout_height="match_parent"
                android:background="#FF0EA5E9" />

            <View
                android:layout_width="18dp"
                android:layout_height="match_parent"
                android:background="#FF8B5CF6" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>