<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- Frame: Sync & Storage (360x800) -->

    <!-- FRAME: div.frame -->
    <LinearLayout
        android:id="@+id/div_frame"
        android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_rounded" />

    <!-- FRAME: div.frame -->
    <LinearLayout
        android:id="@+id/div_frame"
        android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_rounded">

        <!-- FRAME: div.frame -->
        <LinearLayout
            android:id="@+id/div_frame"
            android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
            android:background="@drawable/bg_rounded" />
    </LinearLayout>

    <!-- FRAME: div.frame -->
    <LinearLayout
        android:id="@+id/div_frame"
        android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#FFF8FAFC">

        <!-- FRAME: div.header -->
        <LinearLayout
            android:id="@+id/div_header"
            android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="40dp">

            <!-- FRAME: div.icon-circle -->
            <LinearLayout
                android:id="@+id/div_icon_circle"
                android:orientation="horizontal"
        android:layout_width="40dp"
        android:layout_height="40dp"
                android:background="@drawable/bg_rounded">

                <!-- INSTANCE: Component 1 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/component_1"
        android:layout_width="20dp"
        android:layout_height="20dp">

                    <!-- VECTOR: Vector -->
                    <ImageView
                        android:id="@+id/vector"
                        android:src="@drawable/ic_vector"
                        android:scaleType="fitXY"
        android:layout_width="18dp"
        android:layout_height="13dp" />

                    <!-- VECTOR: Vector -->
                    <ImageView
                        android:id="@+id/vector"
                        android:src="@drawable/ic_vector"
                        android:scaleType="fitXY"
        android:layout_width="3dp"
        android:layout_height="3dp" />

                    <!-- VECTOR: Vector -->
                    <ImageView
                        android:id="@+id/vector"
                        android:src="@drawable/ic_vector"
                        android:scaleType="fitXY"
        android:layout_width="3dp"
        android:layout_height="3dp" />

                    <!-- VECTOR: Vector -->
                    <ImageView
                        android:id="@+id/vector"
                        android:src="@drawable/ic_vector"
                        android:scaleType="fitXY"
        android:layout_width="0dp"
        android:layout_height="7dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <!-- FRAME: div -->
            <LinearLayout
                android:id="@+id/div"
                android:orientation="vertical"
        android:layout_width="134dp"
        android:layout_height="39dp">

                <!-- FRAME: h2 -->
                <LinearLayout
                    android:id="@+id/h2"
                    android:orientation="vertical"
        android:layout_width="134dp"
        android:layout_height="23dp"
                    android:paddingLeft="0dp"
                    android:paddingTop="0dp"
                    android:paddingRight="0dp"
                    android:paddingBottom="1dp">

                    <!-- TEXT: Sync & Storage -->
                    <TextView
                        android:id="@+id/sync___storage"
                        android:text="Sync &amp; Storage"
                        android:textSize="17.899999618530273sp"
                        android:textColor="#FF000000"
                        android:gravity="start"
                        android:textStyle="bold"
                        android:fontFamily="Inter"
        android:layout_width="134dp"
        android:layout_height="22dp" />
                </LinearLayout>

                <!-- FRAME: p -->
                <LinearLayout
                    android:id="@+id/p"
                    android:orientation="vertical"
        android:layout_width="134dp"
        android:layout_height="16dp">

                    <!-- TEXT: Manage offline data -->
                    <TextView
                        android:id="@+id/manage_offline_data"
                        android:text="Manage offline data"
                        android:textSize="13sp"
                        android:textColor="#FF64748B"
                        android:gravity="start"
                        android:fontFamily="Inter"
        android:layout_width="123dp"
        android:layout_height="16dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: div.status-box -->
        <LinearLayout
            android:id="@+id/div_status_box"
            android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="71dp"
            android:background="@drawable/bg_rounded"
            android:paddingLeft="17dp"
            android:paddingTop="17dp"
            android:paddingRight="17dp"
            android:paddingBottom="17dp">

            <!-- INSTANCE: Component 1 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/component_1"
        android:layout_width="24dp"
        android:layout_height="24dp">

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="14dp"
        android:layout_height="3dp" />

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="21dp"
        android:layout_height="4dp" />

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="7dp"
        android:layout_height="1dp" />

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="0dp"
        android:layout_height="0dp" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- FRAME: div -->
            <LinearLayout
                android:id="@+id/div"
                android:orientation="vertical"
        android:layout_width="163dp"
        android:layout_height="37dp">

                <!-- FRAME: div.title -->
                <LinearLayout
                    android:id="@+id/div_title"
                    android:orientation="vertical"
        android:layout_width="163dp"
        android:layout_height="18dp">

                    <!-- TEXT: Online -->
                    <TextView
                        android:id="@+id/online"
                        android:text="Online"
                        android:textSize="14.600000381469727sp"
                        android:textColor="#FF0F172A"
                        android:gravity="start"
                        android:textStyle="bold"
                        android:fontFamily="Inter"
        android:layout_width="47dp"
        android:layout_height="18dp" />
                </LinearLayout>

                <!-- FRAME: div.desc -->
                <LinearLayout
                    android:id="@+id/div_desc"
                    android:orientation="vertical"
        android:layout_width="163dp"
        android:layout_height="15dp">

                    <!-- TEXT: Connected to cloud services -->
                    <TextView
                        android:id="@+id/connected_to_cloud_services"
                        android:text="Connected to cloud services"
                        android:textSize="12sp"
                        android:textColor="#FF64748B"
                        android:gravity="start"
                        android:fontFamily="Inter"
        android:layout_width="163dp"
        android:layout_height="15dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: div.card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/div_card"
        android:layout_width="360dp"
        android:layout_height="138dp"
            android:background="@drawable/bg_rounded">

            <!-- FRAME: div.row -->
            <LinearLayout
                android:id="@+id/div_row"
                android:orientation="horizontal"
        android:layout_width="318dp"
        android:layout_height="37dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="21dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

                <!-- FRAME: div -->
                <LinearLayout
                    android:id="@+id/div"
                    android:orientation="vertical"
        android:layout_width="162dp"
        android:layout_height="37dp">

                    <!-- FRAME: div.title -->
                    <LinearLayout
                        android:id="@+id/div_title"
                        android:orientation="vertical"
        android:layout_width="162dp"
        android:layout_height="18dp">

                        <!-- TEXT: Auto Sync -->
                        <TextView
                            android:id="@+id/auto_sync"
                            android:text="Auto Sync"
                            android:textSize="14.600000381469727sp"
                            android:textColor="#FF0F172A"
                            android:gravity="start"
                            android:textStyle="bold"
                            android:fontFamily="Inter"
        android:layout_width="74dp"
        android:layout_height="18dp" />
                    </LinearLayout>

                    <!-- FRAME: div.desc -->
                    <LinearLayout
                        android:id="@+id/div_desc"
                        android:orientation="vertical"
        android:layout_width="162dp"
        android:layout_height="15dp">

                        <!-- TEXT: Sync changes automatically -->
                        <TextView
                            android:id="@+id/sync_changes_automatically"
                            android:text="Sync changes automatically"
                            android:textSize="12.199999809265137sp"
                            android:textColor="#FF64748B"
                            android:gravity="start"
                            android:fontFamily="Inter"
        android:layout_width="162dp"
        android:layout_height="15dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- FRAME: label.switch -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/label_switch"
        android:layout_width="44dp"
        android:layout_height="24dp">

                    <!-- FRAME: span.slider -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/span_slider"
        android:layout_width="44dp"
        android:layout_height="24dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
                        android:background="@drawable/bg_rounded">

                        <!-- RECTANGLE: ::before -->
                        <LinearLayout
                            android:id="@+id/__before"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="23dp"
        android:layout_marginTop="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
                            android:background="@drawable/bg_rounded" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <!-- FRAME: div -->
            <LinearLayout
                android:id="@+id/div"
                android:orientation="horizontal"
        android:layout_width="318dp"
        android:layout_height="17dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="81dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

                <!-- FRAME: span -->
                <LinearLayout
                    android:id="@+id/span"
                    android:orientation="vertical"
        android:layout_width="90dp"
        android:layout_height="17dp">

                    <!-- TEXT: Cloud Storage -->
                    <TextView
                        android:id="@+id/cloud_storage"
                        android:text="Cloud Storage"
                        android:textSize="13.100000381469727sp"
                        android:textColor="#FF000000"
                        android:gravity="start"
                        android:fontFamily="Inter"
        android:layout_width="90dp"
        android:layout_height="16dp" />
                </LinearLayout>

                <!-- FRAME: span -->
                <LinearLayout
                    android:id="@+id/span"
                    android:orientation="vertical"
        android:layout_width="87dp"
        android:layout_height="17dp">

                    <!-- TEXT: 1.2 GB / 5 GB -->
                    <TextView
                        android:id="@+id/1_2_gb___5_gb"
                        android:text="1.2 GB / 5 GB"
                        android:textSize="14sp"
                        android:textColor="#FF64748B"
                        android:gravity="start"
                        android:fontFamily="Inter"
        android:layout_width="87dp"
        android:layout_height="17dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- FRAME: div.progress-container -->
            <LinearLayout
                android:id="@+id/div_progress_container"
                android:orientation="horizontal"
        android:layout_width="318dp"
        android:layout_height="8dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="109dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
                android:background="@drawable/bg_rounded">

                <!-- RECTANGLE: div -->
                <LinearLayout
                    android:id="@+id/div"
        android:layout_width="54dp"
        android:layout_height="8dp"
                    android:background="#FF3B82F6" />

                <!-- RECTANGLE: div -->
                <LinearLayout
                    android:id="@+id/div"
        android:layout_width="90dp"
        android:layout_height="8dp"
                    android:background="#FF0EA5E9" />

                <!-- RECTANGLE: div -->
                <LinearLayout
                    android:id="@+id/div"
        android:layout_width="18dp"
        android:layout_height="8dp"
                    android:background="#FF8B5CF6" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- FRAME: button.btn-danger -->
        <LinearLayout
            android:id="@+id/button_btn_danger"
            android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="54dp"
            android:background="@drawable/bg_rounded"
            android:paddingLeft="16dp"
            android:paddingTop="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="16dp">

            <!-- INSTANCE: Component 1 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/component_1"
        android:layout_width="20dp"
        android:layout_height="20dp">

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="15dp"
        android:layout_height="0dp" />

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
        android:layout_width="12dp"
        android:layout_height="17dp" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- TEXT: Clear Local Cache -->
            <TextView
                android:id="@+id/clear_local_cache"
                android:text="Clear Local Cache"
                android:textSize="14.600000381469727sp"
                android:textColor="#FFEF4444"
                android:gravity="center"
                android:textStyle="bold"
                android:fontFamily="Inter"
        android:layout_width="129dp"
        android:layout_height="18dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>