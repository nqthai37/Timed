<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardHabit"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/slate_100"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Habit Icon -->
        <ImageView
            android:id="@+id/iv_habit_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_focus" />

        <!-- Habit Title -->
        <TextView
            android:id="@+id/tv_habit_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:text="Chạy bộ 30 phút"
            android:textColor="@color/slate_900"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/iv_check_button"
            app:layout_constraintStart_toEndOf="@+id/iv_habit_icon"
            app:layout_constraintTop_toTopOf="@+id/iv_habit_icon" />

        <!-- Habit Description / Subtitle -->
        <TextView
            android:id="@+id/tv_habit_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chưa hoàn thành"
            android:textColor="@color/slate_500"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/iv_check_button"
            app:layout_constraintStart_toStartOf="@+id/tv_habit_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_habit_title" />

        <!-- Streak Display -->
        <TextView
            android:id="@+id/tv_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="🔥 12 days"
            android:textColor="@color/orange_500"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/tv_habit_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_habit_subtitle"
            tools:visibility="visible" />

        <!-- Check Button -->
        <ImageView
            android:id="@+id/iv_check_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_check_gray"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_check_blue" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

