<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/aiSchedulingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".Features.AI.AiSchedulingActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"       
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Scheduling"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart task management"
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_magic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="@color/background_light"
            android:padding="10dp"
            android:src="@drawable/ic_ai_schedule"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#2563EB" />
    </androidx.constraintlayout.widget.ConstraintLayout>



    <LinearLayout
        android:id="@+id/ll_prompt_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/clHeader">

        <TextView
            android:id="@+id/tv_prompt_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="What do you want to schedule?"
            android:textColor="#0F172A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_selected_calendar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#EFF6FF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="📅 My Calendar ▼"
            android:textColor="#2563EB"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_input_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="@color/slate_100"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/ll_prompt_row">

        <EditText
            android:id="@+id/et_ai_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="E.g. Schedule a team sync tomorrow at 10 AM"
            android:padding="12dp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8"
            android:textSize="14sp"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="1"
            android:maxLines="5"
            android:gravity="center_vertical|start"
            android:scrollbars="vertical" />

        <ImageView
            android:id="@+id/iv_send"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="@color/primary"
            android:padding="10dp"
            android:src="@drawable/ic_send"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_try_these"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="Try these:"
        android:textColor="#64748B"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_input_box" />

    <HorizontalScrollView
        android:id="@+id/sv_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/tv_try_these">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_try_these"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:singleLine="true">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&quot;Lunch with John on Friday&quot;"
                android:textColor="#475569"
                android:background="@drawable/bg_day_event_light"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&quot;Gym every Monday 7am&quot;"
                android:textColor="#475569"
                android:background="@drawable/bg_day_event_light"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&quot;Meeting tonight at 10pm&quot;"
                android:textColor="#475569"
                android:background="@drawable/bg_day_event_light"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tv_recent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="Quick Prompts"
        android:textColor="#0F172A"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sv_chips" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ai_schedules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_recent" />

    <TextView
        android:id="@+id/tv_empty_templates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You haven't saved any templates yet. \nSchedule an event using the AI and save it!"
        android:textAlignment="center"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_recent" />

</androidx.constraintlayout.widget.ConstraintLayout>
