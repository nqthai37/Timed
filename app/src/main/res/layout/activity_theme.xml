<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FAFC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theme &amp; Appearance"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customize the look of your app"
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@+id/clHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Appearance Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appearance"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/ll_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#FFFFFF"
                android:elevation="1dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:id="@+id/ll_appearance_light"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded_appearance_selected"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_light"
                        android:tint="#1E40AF"
                        android:scaleType="centerInside"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Light"
                        android:textColor="#1E40AF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_appearance_dark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded"
                    android:padding="12dp"
                    android:layout_marginHorizontal="4dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_dark"
                        android:tint="#7C3AED"
                        android:scaleType="centerInside"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_appearance_system"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_system"
                        android:tint="#7C3AED"
                        android:scaleType="centerInside"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Primary Color Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Primary Color"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/ll_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#FFFFFF"
                android:elevation="1dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <!-- Blue (Selected) -->
                <FrameLayout
                    android:id="@+id/fl_color_blue"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_color_circle"
                        android:tint="#1E40AF"
                        android:scaleType="centerInside" />

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_check_circle"
                        android:tint="#1E40AF"
                        android:scaleType="centerInside"
                        android:layout_gravity="center" />
                </FrameLayout>

                <!-- Purple -->
                <ImageView
                    android:id="@+id/iv_color_purple"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_color_circle"
                    android:tint="#7C3AED"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Pink -->
                <ImageView
                    android:id="@+id/iv_color_pink"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_color_circle"
                    android:tint="#DB2777"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Red -->
                <ImageView
                    android:id="@+id/iv_color_red"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_color_circle"
                    android:tint="#DC2626"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Orange -->
                <ImageView
                    android:id="@+id/iv_color_orange"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_color_circle"
                    android:tint="#EA580C"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Green -->
                <ImageView
                    android:id="@+id/iv_color_green"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_color_circle"
                    android:tint="#059669"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <!-- Preview Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#FFFFFF"
                android:elevation="1dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_event"
                        android:tint="#1E40AF"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sample Event"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today at 2:00 PM"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This is how your calendar will look"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Font Size Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Size"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#FFFFFF"
                android:elevation="1dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginEnd="12dp" />

                    <SeekBar
                        android:id="@+id/seekbar_font_size"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="50"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>