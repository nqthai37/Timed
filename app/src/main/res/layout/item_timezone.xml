<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@drawable/bg_rounded"
    android:backgroundTint="@color/slate_100"
    android:layout_marginBottom="8dp"
    android:elevation="1dp"
    android:gravity="center_vertical">

    <!-- Timezone icon -->
    <ImageView
        android:id="@+id/iv_tz_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#F1F5F9"
        android:padding="9dp"
        android:src="@drawable/ic_globe"
        app:tint="#3B82F6"
        android:layout_marginEnd="12dp"/>

    <!-- Info section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_tz_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTC+00:00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tv_tz_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coordinated Universal Time\nLondon, Dublin, Lisbon"
            android:textSize="12sp"
            android:textColor="#64748B"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Current time in this timezone -->
    <TextView
        android:id="@+id/tv_tz_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:50 PM"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"/>

</LinearLayout>
