<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:id="@+id/sheetHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#CBD5E1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sheetHandle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="Quay lại"
            android:textColor="@color/slate_900"
            app:icon="@drawable/ic_back"
            app:iconPadding="6dp"
            app:iconTint="@color/slate_900" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Lặp lại"
            android:textColor="@color/slate_900"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="Xong"
            android:textColor="@color/blue_600"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tần suất"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/pillDaily"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_recurrence_pill_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Hàng ngày"
                        android:textColor="@color/blue_700"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pillWeekly"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_recurrence_pill_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Hàng tuần"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pillMonthly"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_recurrence_pill_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Hàng tháng"
                        android:textColor="@color/blue_700"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pillYearly"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_recurrence_pill_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Hàng năm"
                        android:textColor="@color/blue_700"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pillCustom"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_recurrence_pill_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Tùy chỉnh"
                        android:textColor="@color/blue_700"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Khoảng lặp"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recurrence_card"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lặp mỗi"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/stepperInterval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_recurrence_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/btnIntervalMinus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_recurrence_stepper_button"
                            android:gravity="center"
                            android:text="-"
                            android:textColor="@color/slate_900"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvIntervalValue"
                            android:layout_width="36dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/slate_900"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnIntervalPlus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_recurrence_stepper_button"
                            android:gravity="center"
                            android:text="+"
                            android:textColor="@color/slate_900"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvIntervalUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="tuần"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWeekdayLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ngày trong tuần"
                    android:textColor="@color/slate_600"
                    android:textSize="13sp" />

                <HorizontalScrollView
                    android:id="@+id/scrollWeekdays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutWeekdayChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipMon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_selected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T2"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipTue"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T3"
                            android:textColor="@color/slate_600"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipWed"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_selected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T4"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipThu"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T5"
                            android:textColor="@color/slate_600"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipFri"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_selected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T6"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipSat"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_recurrence_day_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="T7"
                            android:textColor="@color/slate_600"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipSun"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_recurrence_day_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="CN"
                            android:textColor="@color/slate_600"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Quy tắc nâng cao"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutAdvancedRule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recurrence_card"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vị trí"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutPositionField"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_recurrence_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:id="@+id/tvPositionValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thứ nhất"
                            android:textColor="@color/slate_900"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="@color/slate_500" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ngày"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutDayField"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_recurrence_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:id="@+id/tvDayValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thứ Hai"
                            android:textColor="@color/slate_900"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="@color/slate_500" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAdvancedExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Mẫu: Thứ Hai đầu tiên mỗi tháng"
                    android:textColor="@color/slate_500"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Ngoại lệ"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recurrence_card"
                android:orientation="vertical"
                android:padding="12dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/llExceptionsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    </LinearLayout>
                </HorizontalScrollView>

                <LinearLayout
                    android:id="@+id/btnAddException"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_recurrence_pill_inactive"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_add"
                        app:tint="@color/blue_600" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Thêm ngày ngoại lệ"
                        android:textColor="@color/blue_700"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Kết thúc"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recurrence_card"
                android:orientation="vertical"
                android:padding="12dp">

                <RadioGroup
                    android:id="@+id/rgEndOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbNever"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/blue_600"
                        android:text="Không bao giờ"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rbOnDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:buttonTint="@color/blue_600"
                        android:text="Vào ngày cụ thể"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutEndDateRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="32dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_calendar_today"
                            app:tint="@color/slate_500" />

                        <TextView
                            android:id="@+id/tvEndDateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_recurrence_field"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="10dp"
                            android:text="15/06/2026"
                            android:textColor="@color/slate_900"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/rbAfterCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:buttonTint="@color/blue_600"
                        android:text="Sau N lần lặp"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutEndCountRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="32dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_recurrence_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="4dp">

                            <TextView
                                android:id="@+id/btnCountMinus"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_recurrence_stepper_button"
                                android:gravity="center"
                                android:text="-"
                                android:textColor="@color/slate_900"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCountValue"
                                android:layout_width="36dp"
                                android:layout_height="28dp"
                                android:gravity="center"
                                android:text="10"
                                android:textColor="@color/slate_900"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnCountPlus"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_recurrence_stepper_button"
                                android:gravity="center"
                                android:text="+"
                                android:textColor="@color/slate_900"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="lần"
                            android:textColor="@color/slate_600"
                            android:textSize="13sp" />
                    </LinearLayout>
                </RadioGroup>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Xem trước"
                android:textColor="@color/slate_600"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recurrence_preview"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lặp hàng tuần vào T2, T4, T6. Kết thúc sau 10 lần lặp."
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
