<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <CheckBox
        android:id="@+id/cbCalendarVisibility"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:scaleX="0.8"
        android:scaleY="0.8" />

    <View
        android:id="@+id/vCalendarColorDot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_calendar_color_dot" />

    <TextView
        android:id="@+id/tvCalendarName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/slate_900"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/btnEditCalendar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Edit calendar"
        android:scaleType="centerInside"
        android:src="@drawable/ic_edit" />

</LinearLayout>
