<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">
        
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_rounded"
            android:src="@drawable/ic_back"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timezone"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#FFFFFF"
        android:padding="20dp"
        android:elevation="1dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:50 AM"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#0F172A"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current time"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detected location"
                android:textSize="14sp"
                android:textColor="#64748B" />
                
            <TextView
                android:id="@+id/tv_detected_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ho Chi Minh City"
                android:textSize="14sp"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
                
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_r_arrow"
                app:tint="#64748B"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_add_timezone"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_day_event_light"

        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">
        
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_input_add" 
            app:tint="@color/primary"
            android:layout_marginEnd="8dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add timezone"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="15sp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_timezone_settings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"/>
        
</LinearLayout>