<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- Frame: Habit Tracker (360x800) -->

    <!-- FRAME: div.frame -->
    <LinearLayout
        android:id="@+id/div_frame"
        android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_rounded">

        <!-- FRAME: div.frame -->
        <LinearLayout
            android:id="@+id/div_frame"
            android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="800dp"
            android:background="#FFF8FAFC">

            <!-- FRAME: div.header:margin -->
            <LinearLayout
                android:id="@+id/div_header_margin"
                android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="48dp"
                android:paddingLeft="0dp"
                android:paddingTop="0dp"
                android:paddingRight="0dp"
                android:paddingBottom="8dp">

                <!-- FRAME: div.header -->
                <LinearLayout
                    android:id="@+id/div_header"
                    android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="40dp">

                    <!-- FRAME: div.icon-circle -->
                    <LinearLayout
                        android:id="@+id/div_icon_circle"
                        android:orientation="horizontal"
        android:layout_width="40dp"
        android:layout_height="40dp"
                        android:background="@drawable/bg_rounded">

                        <!-- INSTANCE: Component 1 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/component_1"
        android:layout_width="20dp"
        android:layout_height="20dp">

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
        android:layout_width="15dp"
        android:layout_height="15dp" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <!-- FRAME: div -->
                    <LinearLayout
                        android:id="@+id/div"
                        android:orientation="vertical"
        android:layout_width="144dp"
        android:layout_height="38dp">

                        <!-- FRAME: h2 -->
                        <LinearLayout
                            android:id="@+id/h2"
                            android:orientation="vertical"
        android:layout_width="144dp"
        android:layout_height="22dp"
                            android:paddingLeft="0dp"
                            android:paddingTop="0dp"
                            android:paddingRight="0dp"
                            android:paddingBottom="1dp">

                            <!-- TEXT: Habit Tracker -->
                            <TextView
                                android:id="@+id/habit_tracker"
                                android:text="Habit Tracker"
                                android:textSize="17.299999237060547sp"
                                android:textColor="#FF000000"
                                android:gravity="start"
                                android:textStyle="bold"
                                android:fontFamily="Inter"
        android:layout_width="115dp"
        android:layout_height="21dp" />
                        </LinearLayout>

                        <!-- FRAME: p -->
                        <LinearLayout
                            android:id="@+id/p"
                            android:orientation="vertical"
        android:layout_width="144dp"
        android:layout_height="16dp">

                            <!-- TEXT: Build better habits daily -->
                            <TextView
                                android:id="@+id/build_better_habits_daily"
                                android:text="Build better habits daily"
                                android:textSize="12.899999618530273sp"
                                android:textColor="#FF64748B"
                                android:gravity="start"
                                android:fontFamily="Inter"
        android:layout_width="144dp"
        android:layout_height="16dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- FRAME: div.habit-row -->
            <LinearLayout
                android:id="@+id/div_habit_row"
                android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="74dp"
                android:background="@drawable/bg_rounded"
                android:paddingLeft="17dp"
                android:paddingTop="17dp"
                android:paddingRight="17dp"
                android:paddingBottom="17dp">

                <!-- FRAME: div.habit-info -->
                <LinearLayout
                    android:id="@+id/div_habit_info"
                    android:orientation="horizontal"
        android:layout_width="136dp"
        android:layout_height="40dp">

                    <!-- FRAME: div.habit-icon -->
                    <LinearLayout
                        android:id="@+id/div_habit_icon"
                        android:orientation="horizontal"
        android:layout_width="40dp"
        android:layout_height="40dp"
                        android:background="@drawable/bg_rounded">

                        <!-- INSTANCE: Component 1 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/component_1"
        android:layout_width="20dp"
        android:layout_height="20dp">

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
        android:layout_width="12dp"
        android:layout_height="16dp" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <!-- FRAME: div -->
                    <LinearLayout
                        android:id="@+id/div"
                        android:orientation="vertical"
        android:layout_width="84dp"
        android:layout_height="35dp">

                        <!-- FRAME: div.title -->
                        <LinearLayout
                            android:id="@+id/div_title"
                            android:orientation="vertical"
        android:layout_width="84dp"
        android:layout_height="17dp">

                            <!-- TEXT: Drink Water -->
                            <TextView
                                android:id="@+id/drink_water"
                                android:text="Drink Water"
                                android:textSize="14.399999618530273sp"
                                android:textColor="#FF64748B"
                                android:gravity="start"
                                android:textStyle="bold"
                                android:fontFamily="Inter"
        android:layout_width="84dp"
        android:layout_height="17dp" />
                        </LinearLayout>

                        <!-- FRAME: div.streak -->
                        <LinearLayout
                            android:id="@+id/div_streak"
                            android:orientation="vertical"
        android:layout_width="84dp"
        android:layout_height="14dp">

                            <!-- TEXT: 7 day streak -->
                            <TextView
                                android:id="@+id/7_day_streak"
                                android:text="7 day streak"
                                android:textSize="11.300000190734863sp"
                                android:textColor="#FF64748B"
                                android:gravity="start"
                                android:fontFamily="Inter"
        android:layout_width="66dp"
        android:layout_height="14dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- FRAME: div.check-circle -->
                <LinearLayout
                    android:id="@+id/div_check_circle"
                    android:orientation="horizontal"
        android:layout_width="28dp"
        android:layout_height="28dp"
                    android:background="@drawable/bg_rounded"
                    android:paddingLeft="2dp"
                    android:paddingTop="2dp"
                    android:paddingRight="2dp"
                    android:paddingBottom="2dp">

                    <!-- INSTANCE: Component 1 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/component_1"
        android:layout_width="14dp"
        android:layout_height="14dp">

                        <!-- VECTOR: Vector -->
                        <ImageView
                            android:id="@+id/vector"
                            android:src="@drawable/ic_vector"
                            android:scaleType="fitXY"
        android:layout_width="9dp"
        android:layout_height="6dp" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- FRAME: div.habit-row -->
            <LinearLayout
                android:id="@+id/div_habit_row"
                android:orientation="horizontal"
        android:layout_width="360dp"
        android:layout_height="74dp"
                android:background="@drawable/bg_rounded"
                android:paddingLeft="17dp"
                android:paddingTop="17dp"
                android:paddingRight="17dp"
                android:paddingBottom="17dp">

                <!-- FRAME: div.habit-info -->
                <LinearLayout
                    android:id="@+id/div_habit_info"
                    android:orientation="horizontal"
        android:layout_width="124dp"
        android:layout_height="40dp">

                    <!-- FRAME: div.habit-icon -->
                    <LinearLayout
                        android:id="@+id/div_habit_icon"
                        android:orientation="horizontal"
        android:layout_width="40dp"
        android:layout_height="40dp"
                        android:background="@drawable/bg_rounded">

                        <!-- INSTANCE: Component 1 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/component_1"
        android:layout_width="20dp"
        android:layout_height="20dp">

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
        android:layout_width="17dp"
        android:layout_height="17dp" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <!-- FRAME: div -->
                    <LinearLayout
                        android:id="@+id/div"
                        android:orientation="vertical"
        android:layout_width="72dp"
        android:layout_height="36dp">

                        <!-- FRAME: div.title -->
                        <LinearLayout
                            android:id="@+id/div_title"
                            android:orientation="vertical"
        android:layout_width="72dp"
        android:layout_height="18dp">

                            <!-- TEXT: Exercise -->
                            <TextView
                                android:id="@+id/exercise"
                                android:text="Exercise"
                                android:textSize="14.800000190734863sp"
                                android:textColor="#FF0F172A"
                                android:gravity="start"
                                android:textStyle="bold"
                                android:fontFamily="Inter"
        android:layout_width="62dp"
        android:layout_height="18dp" />
                        </LinearLayout>

                        <!-- FRAME: div.streak -->
                        <LinearLayout
                            android:id="@+id/div_streak"
                            android:orientation="vertical"
        android:layout_width="72dp"
        android:layout_height="14dp">

                            <!-- TEXT: 12 day streak -->
                            <TextView
                                android:id="@+id/12_day_streak"
                                android:text="12 day streak"
                                android:textSize="11.399999618530273sp"
                                android:textColor="#FF64748B"
                                android:gravity="start"
                                android:fontFamily="Inter"
        android:layout_width="72dp"
        android:layout_height="14dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- RECTANGLE: div.check-circle -->
                <LinearLayout
                    android:id="@+id/div_check_circle"
        android:layout_width="28dp"
        android:layout_height="28dp"
                    android:background="@drawable/bg_rounded" />
            </LinearLayout>

            <!-- FRAME: button.btn-outline -->
            <LinearLayout
                android:id="@+id/button_btn_outline"
                android:orientation="vertical"
        android:layout_width="360dp"
        android:layout_height="51dp"
                android:background="@drawable/bg_rounded"
                android:paddingLeft="16dp"
                android:paddingTop="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="16dp">

                <!-- TEXT: + Add New Habit -->
                <TextView
                    android:id="@+id/__add_new_habit"
                    android:text="+ Add New Habit"
                    android:textSize="14.399999618530273sp"
                    android:textColor="#FF0F172A"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:fontFamily="Inter"
        android:layout_width="118dp"
        android:layout_height="17dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>